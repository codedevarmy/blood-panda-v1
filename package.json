{
  "name": "blood-panda-v1",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check .",
    "start": "node .output/server/index.mjs",
    "post-cta-init": "pnpm dlx create-db@latest --user-agent tanstack/tsrouter",
    "db:init": "dotenv -e .env pnpx prisma init --output ../src/generated/prisma",
    "db:migrate": "dotenv -e .env pnpx prisma migrate dev",
    "db:push": "dotenv -e .env pnpx prisma db push",
    "db:pull": "dotenv -e .env pnpx prisma db pull",
    "db:generate": "dotenv -e .env pnpx prisma generate",
    "db:seed": "dotenv -e .env pnpx prisma db seed",
    "db:reset": "dotenv -e .env pnpx prisma migrate reset",
    "db:dev": "pnpm db:push && pnpm db:generate",
    "db:studio": "pnpm dlx prisma studio --browser none",
    "auth:gen": "pnpm dlx auth@latest generate --config \"./src/lib/auth.ts\" --output \"./src/lib/auth-generated.ts\" --yes",
    "email:dev": "dotenv -e .env email dev --port 3001"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.23",
